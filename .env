# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: mock | openai | ollama
# Default is mock — works with no API key, deterministic, zero-cost.
MODEL_PROVIDER=mock

# ── OpenAI (set MODEL_PROVIDER=openai to activate) ───────────────────────────
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini

# ── Ollama (set MODEL_PROVIDER=ollama to activate) ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# MODEL_NAME=llama3   ← uncomment and set MODEL_PROVIDER=ollama

# ── Application ───────────────────────────────────────────────────────────────
DB_PATH=./hr_agent.db
STM_MAX_ENTRIES=10
LTM_SIGNIFICANCE_THRESHOLD=0.7
REQUEST_TIMEOUT=10
MAX_RETRIES=3
