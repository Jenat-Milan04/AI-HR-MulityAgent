# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | mock
# RECOMMENDED: Use gemini for assignment submission
MODEL_PROVIDER=gemini

# ── Google Gemini (PRIMARY - set MODEL_PROVIDER=gemini to activate) ──────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
MODEL_NAME=google/gemini-2.5-flash

# ── Ollama (set MODEL_PROVIDER=ollama to activate) ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# MODEL_NAME=llama3   ← uncomment and set MODEL_PROVIDER=ollama

# ── Application ───────────────────────────────────────────────────────────────
DB_PATH=./hr_agent.db
STM_MAX_ENTRIES=10
LTM_SIGNIFICANCE_THRESHOLD=0.7
REQUEST_TIMEOUT=10
MAX_RETRIES=3